# --- OCR proxy ---------------------------------------------------------------
# Server-held Google AI (Gemini) key. Users never see or supply their own key.
# Create one at https://aistudio.google.com/apikey
GEMINI_API_KEY=AIza...

# --- Shared-bill storage (Upstash Redis via the Vercel Marketplace) ----------
# Add the "Upstash for Redis" integration in the Vercel dashboard and these two
# vars are injected automatically. For local dev, copy them from the Upstash
# console into .env.local.
UPSTASH_REDIS_REST_URL=https://xxxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=xxxx

# --- Public base URL (optional) ----------------------------------------------
# Used to build share links. If unset, the API derives it from the request host
# (correct on Vercel). Set it for local dev if you want absolute links.
# NEXT_PUBLIC_BASE_URL=https://tabby.example.com
